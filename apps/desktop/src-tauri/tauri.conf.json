{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NodeAI",
  "version": "0.1.0",
  "identifier": "com.nodeai.desktop",
  "build": {
    "beforeDevCommand": "bash ../../scripts/stage_cloud_sidecar.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash ../../scripts/stage_cloud_sidecar.sh && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NodeAI",
        "width": 1280,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/nodeai-cloud-dev"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
